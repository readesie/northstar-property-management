# NorthStar Property Management — Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Email (required) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password_here
ALERT_FROM=you@gmail.com
OWNER_EMAIL=you@gmail.com

# ── SMS via Twilio (optional) ──────────────────────────────────
# Free tier works fine. https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Data ──────────────────────────────────────────────────────
DATA_DIR=./data
